  /// MГғВ©tricas de desempenho dos anГғВәncios

  @@unique([externalId, portalId])
  // ГғпҝҪndices
  @@index([propertyId])
  @@index([portalId])
  @@index([status])
  @@index([publishedAt])
  @@index([portalType])
  @@index([externalId])
}

/// Modelo de Pacotes (Planos)
