// ============================================
// SCHEMA PRISMA - CRM IMOBILIГғпҝҪRIO IMOBWEB
// ============================================
// Arquitetura multi-tenant com organizaГғВ§ГғВЈo (imobiliГғВЎria)
// Suporte a integraГғВ§ГғВөes com portais de imГғВіveis
// Sistema de conversas WhatsApp com IA
// GestГғВЈo completa de leads e proprietГғВЎrios
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

/// Status geral de entidades
enum EntityStatus {
  ATIVO // Entidade ativa no sistema
  INATIVO // Entidade desativada
  ARQUIVADO // Entidade arquivada (nГғВЈo mais em uso)
}

/// Status de imГғВіvel
enum PropertyStatus {
  DISPONIVEL // ImГғВіvel disponГғВӯvel para venda/locaГғВ§ГғВЈo
  VENDIDO // ImГғВіvel vendido
  ALUGADO // ImГғВіvel alugado
  RESERVADO // ImГғВіvel reservado
  DESATUALIZADO // ImГғВіvel com dados desatualizados
  SUSPENSO // ImГғВіvel suspenso por pendГғВӘncias
  RASCUNHO // ImГғВіvel em rascunho (nГғВЈo publicado)
}

/// Tipo de imГғВіvel
enum PropertyType {
  APARTAMENTO // Apartamento
  CASA // Casa
  TERRENO // Terreno
  COMERCIAL // ImГғВіvel comercial
  COMERCIAL_LOJA // Loja comercial
  COMERCIAL_GARAGEM // Garagem comercial
  COMERCIAL_LOTE // Lote comercial
  COMERCIAL_OUTRO // Outro comercial
  SITIO // SГғВӯtio
  CHACARA // ChГғВЎcara
  FAZENDA // Fazenda
  CONDOMINIO // CondomГғВӯnio fechado
  GARAGEM // Garagem
  CABINE // Cabine
  QUADRA // Quadra
  TERRENO_RESIDENCIAL // Terreno residencial
  SITIO_RESIDENCIAL // SГғВӯtio residencial
  CHACARA_RESIDENCIAL // ChГғВЎcara residencial
  OUTRO // Outro tipo
}

/// Tipo de negГғВіcio
enum BusinessType {
  VENDA // Venda
  LOCACAO // LocaГ§ГЈo
  VENDA_LOCACAO // Venda e locaГ§ГЈo
}

/// SituaГғВ§ГғВЈo do imГғВіvel
enum PropertySituation {
  NOVO // ImГғВіvel novo
  SEM_NOVO // ImГғВіvel usado
  NA_MAO // ImГғВіvel na mГғВЈo
  EM_CONSTRUCAO // Em construГғВ§ГғВЈo
  TERMINADO // Terminado
}

/// SituaГғВ§ГғВЈo do proprietГғВЎrio
enum OwnerSituation {
  DISPONIVEL // DisponГғВӯvel para contato
  OCULTO // Oculto no sistema
  INATIVO // Inativo
  VENDIDO // JГғВЎ vendeu
  ALUGADO // JГғВЎ alugou
}

/// Status do lead
enum LeadStatus {
  NOVO // Lead novo
  CONTATADO // JГғВЎ foi contatado
  INTERESSADO // Mostrou interesse
  AGUARDANDO // Aguardando resposta
  PERDIDO // Lead perdido
  CONVERTIDO // Lead convertido (comprador/locador)
  ARQUIVADO // Lead arquivado
}

/// Status da conversa
enum ConversationStatus {
  ATIVA // Conversa ativa
  INATIVA // Conversa inativa
  RESOLVIDA // Conversa resolvida
  ENCERRADA // Conversa encerrada
  ENVIADO // Mensagem enviada
  ENTREGUE // Mensagem entregue
  LIDA // Mensagem lida
  ERRO // Erro no envio
}

/// Status do anГғВәncio
enum AnnouncementStatus {
  RASCUNHO // AnГғВәncio em rascunho
  PUBLICADO // AnГғВәncio publicado
  ATIVO // AnГғВәncio ativo
  INATIVO // AnГғВәncio inativo
  SUSPENSO // AnГғВәncio suspenso
  EXPIRADO // AnГғВәncio expirado
  RENOVADO // AnГғВәncio renovado
}

/// Status do pacote
enum PackageStatus {
  ATIVO // Pacote ativo
  INATIVO // Pacote inativo
  EXPIRADO // Pacote expirado
  CANCELADO // Pacote cancelado
}

/// Tipo de plano
enum PackageType {
  BASICO // Plano bГғВЎsico
  DESTAQUE // Plano destaque
  PREMIUM // Plano premium
  CORPORATIVO // Plano corporativo
  CUSTOMIZADO // Plano customizado
}

/// Status da integraГғВ§ГғВЈo com portal
enum PortalIntegrationStatus {
  ATIVO // IntegraГғВ§ГғВЈo ativa
  INATIVO // IntegraГғВ§ГғВЈo inativa
  SUSPENSO // IntegraГғВ§ГғВЈo suspensa
  ERRO // Erro na integraГғВ§ГғВЈo
}

/// Tipo de portal
enum PortalType {
  ZAP
  VIVAREAL
  OLX
  IMOVELWEB
  CHAVES_NA_MAO
  VRSYNC
  CUSTOM
}

/// Tipo de comunicaГ§ГЈo
enum CommunicationType {
  EMAIL
  SMS
}

/// Status do envio de comunicaГ§ГЈo
enum CommunicationStatus {
  PENDENTE
  ENVIADO
  ENTREGUE
  LIDO
  FALHOU
  CANCELADO
}

/// Tipo de usuГғВЎrio
enum UserRole {
  // Roles de Plataforma (Equipe ImobWeb)
  PLATFORM_MASTER // Super Admin com acesso total
  PLATFORM_MARKETING // Marketing da plataforma
  PLATFORM_FINANCE // Financeiro da plataforma
  PLATFORM_SUPPORT // Suporte da plataforma

  // Roles de AgГӘncia (ImobiliГЎria)
  AGENCY_MASTER // Dono/Administrador da ImobiliГЎria
  AGENCY_SALES // Corretor / Vendas
  AGENCY_HR // RH / GestГЈo de Equipe
  AGENCY_MARKETING // Marketing da ImobiliГЎria
  AGENCY_FINANCE // Financeiro da ImobiliГЎria
  AGENCY_SUPPORT // Suporte da ImobiliГЎria

  // Legado (Para compatibilidade/MigraГ§ГЈo)
  ADMIN
  GERENTE
  CORRETOR
  ASSISTENTE
}

/// Tipo de notificaГғВ§ГғВЈo
enum NotificationType {
  INFO // InformaГғВ§ГғВЈo geral
  WARNING // Aviso importante
  ERROR // Erro do sistema
  SUCCESS // Sucesso operacional
  LEAD // NotificaГғВ§ГғВЈo de lead
  PROPERTY // NotificaГғВ§ГғВЈo de imГғВіvel
  PAYMENT // NotificaГғВ§ГғВЈo de pagamento
  SYSTEM // NotificaГғВ§ГғВЈo do sistema
}

/// Tipo de mГғВ©todo de pagamento
enum PaymentMethod {
  CREDIT_CARD // CartГғВЈo de crГғВ©dito
  DEBIT_CARD // CartГғВЈo de dГғВ©bito
  BOLETO // Boleto bancГғВЎrio
  PIX // PIX
  TRANSFER // TransferГғВӘncia bancГғВЎria
  CASH // Dinheiro
}

/// DireГғВ§ГғВЈo da mensagem WhatsApp
enum MessageDirection {
  INCOMING // Mensagem recebida
  OUTGOING // Mensagem enviada
}

/// Fonte do lead
enum LeadSource {
  WEBSITE // Site da imobiliГғВЎria
  PORTAL // Portal de imГғВіveis
  INDICATION // IndicaГғВ§ГғВЈo
  REFERRAL // IndicaГғВ§ГғВЈo de cliente
  SOCIAL // Rede social
  PHONE // Telefone direto
  WALK_IN // Cliente que chegou na loja
  OTHER // Outra fonte
}

// ============================================
// MODELOS PRINCIPAIS
// ============================================

/// Modelo de UsuГғВЎrios do Sistema (Corretores, Gerentes, Admin)
model User {
  id             String       @id @default(cuid())
  name           String // Nome completo do usuГғВЎrio
  email          String       @unique // Email ГғВәnico para login
  phone          String? // Telefone de contato
  whatsapp       String? // WhatsApp para contato profissional
  password       String // Senha criptografada
  role           UserRole // Papel do usuГғВЎrio no sistema
  permissions    Json? // Overrides de permissГЈo por usuГЎrio (ex: { "denied": ["billing:view"] })
  status         EntityStatus @default(ATIVO) // Status do usuГғВЎrio
  lastLogin      DateTime? // ГғЕЎltimo login do usuГғВЎrio
  avatar         String? // URL do avatar do usuГғВЎrio
  bio            String? // Biografia ou descriГғВ§ГғВЈo do usuГғВЎrio
  department     String? // Departamento ou ГғВЎrea de atuaГғВ§ГғВЈo
  specialization String? // EspecializaГғВ§ГғВЈo do usuГғВЎrio
  createdAt      DateTime     @default(now()) // Data de criaГғВ§ГғВЈo
  updatedAt      DateTime     @updatedAt // Data de atualizaГғВ§ГғВЈo

  // Relacionamentos
  organizationId String // Chave estrangeira para multi-tenant
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relacionamentos com entidades principais
  properties         Property[] // ImГғВіveis criados/gerenciados pelo usuГғВЎrio
  leads              Lead[] // Leads atribuГғВӯdos ao usuГғВЎrio
  conversations      Conversation[] // Conversas do usuГғВЎrio
  notifications      Notification[] // NotificaГғВ§ГғВөes do usuГғВЎrio
  assignedLeads      Lead[]               @relation("AssignedLeads") // Leads atribuГғВӯdos explicitamente
  auditLogs          AuditLog[]
  communicationUsage CommunicationUsage[]
  onboardingProgress OnboardingProgress?

  // ComentГғВЎrios
  /// UsuГғВЎrio do sistema com diferentes nГғВӯveis de permissГғВЈo
  /// Suporta multi-tenant atravГғВ©s da organizaГғВ§ГғВЈo
  propertyVersions PropertyVersion[]

  // ГғпҝҪndices
  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@index([whatsapp])
}

/// Modelo de OrganizaГғВ§ГғВөes (Multi-tenant - ImobiliГғВЎrias)
model Organization {
  id             String       @id @default(cuid())
  name           String // Nome da imobiliГғВЎria
  cnpj           String?      @unique // CNPJ ГғВәnico
  phone          String? // Telefone principal
  email          String?      @unique // Email corporativo
  website        String? // Website da imobiliГғВЎria
  logo           String? // URL do logo da empresa
  address        String? // EndereГғВ§o completo
  neighborhood   String? // Bairro
  city           String? // Cidade
  state          String? // Estado
  cep            String? // CEP
  country        String?      @default("Brasil") // PaГғВӯs
  status         EntityStatus @default(ATIVO) // Status da organizaГғВ§ГғВЈo
  planType       PackageType? // Tipo de plano atual
  maxUsers       Int? // Limite de usuГғВЎrios
  maxProperties  Int? // Limite de imГғВіveis
  maxLeads       Int? // Limite de leads
  features       Json? // Recursos disponГғВӯveis no plano
  settings       Json? // ConfiguraГғВ§ГғВөes personalizadas
  primaryColor   String? // Cor primГғВЎria da marca (White Label)
  secondaryColor String? // Cor secundГғВЎria da marca (White Label)
  isPlatform     Boolean      @default(false) // Indica se Г© a organizaГ§ГЈo gestora (ImobWeb)
  roleQuotas     Json? // Limites de usuГЎrios por papel (ex: {"AGENCY_SALES": 10})
  subDomain      String?      @unique // SubdomГғВӯnio exclusivo da imobiliГғВЎria
  createdAt      DateTime     @default(now()) // Data de criaГғВ§ГғВЈo
  updatedAt      DateTime     @updatedAt // Data de atualizaГғВ§ГғВЈo

  // Relacionamentos
  users              User[] // UsuГғВЎrios da organizaГғВ§ГғВЈo
  properties         Property[] // ImГғВіveis da organizaГғВ§ГғВЈo
  leads              Lead[] // Leads da organizaГғВ§ГғВЈo
  subscriptions      Subscription[] // Assinaturas da organizaГғВ§ГғВЈo
  apiKeys            ApiKey[] // Chaves de API da organizaГғВ§ГғВЈo
  auditLogs          AuditLog[]
  contracts          Contract[] // Contratos da organizaГғВ§ГғВЈo
  portalIntegrations PortalIntegration[] // IntegraГғВ§ГғВөes com portais
  communicationUsage CommunicationUsage[]
  communicationQuota CommunicationQuota[]
  integrationEvents  IntegrationEvent[]
  autoBlockConfigs   AutoBlockConfig[]
  onboardingProgresses OnboardingProgress[]
  adoptionMetrics      AdoptionMetrics[]

  // ComentГғВЎrios
  /// OrganizaГғВ§ГғВЈo principal para suporte multi-tenant
  /// Cada organizaГғВ§ГғВЈo representa uma imobiliГғВЎria diferente

  // ГғпҝҪndices
  @@index([cnpj])
  @@index([email])
  @@index([city])
}

/// Modelo de ImГғВіveis (com +80 campos detalhados)
model Property {
  id               String             @id @default(cuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  title            String // TГғВӯtulo do imГғВіvel
  description      String? // DescriГғВ§ГғВЈo detalhada do imГғВіvel
  code             String? // CГғВіdigo interno do imГғВіvel
  status           PropertyStatus     @default(RASCUNHO) // Status do imГғВіvel
  type             PropertyType // Tipo do imГғВіvel
  businessType     BusinessType // Tipo de negГғВіcio (venda/locaГғВ§ГғВЈo)
  situation        PropertySituation? // SituaГғВ§ГғВЈo do imГғВіvel
  price            Decimal? // PreГғВ§o do imГғВіvel
  priceRent        Decimal? // PreГғВ§o do aluguel
  priceCondominium Decimal? // Valor do condomГғВӯnio
  priceIptu        Decimal? // Valor do IPTU
  priceTax         Decimal? // Valor de taxas
  currency         String?            @default("BRL") // Moeda

  // Medidas e dimensГғВөes
  areaPrivate      Float? // ГғпҝҪrea privativa (mГӮВІ)
  areaCommon       Float? // ГғпҝҪrea comum (mГӮВІ)
  areaUseful       Float? // ГғпҝҪrea ГғВәtil (mГӮВІ)
  areaTotal        Float? // ГғпҝҪrea total (mГӮВІ)
  areaLand         Float? // ГғпҝҪrea do terreno (mГӮВІ)
  areaConstruction Float? // ГғпҝҪrea de construГғВ§ГғВЈo (mГӮВІ)

  // Quartos e banheiros
  bedrooms         Int? // NГғВәmero de quartos
  bedroomsSuites   Int? // NГғВәmero de suГғВӯtes
  bathrooms        Int? // NГғВәmero de banheiros
  bathroomsSocial  Int? // NГғВәmero de banheiros sociais
  bathroomsService Int? // NГғВәmero de banheiros de serviГғВ§o

  // Vagas e garagens
  garages          Int? // NГғВәmero de vagas na garagem
  garagesCovered   Int? // Vagas cobertas
  garagesOpen      Int? // Vagas abertas
  garagesDependent Int? // Vagas para dependentes

  // Andares
  totalFloors  Int? // Total de andares
  currentFloor Int? // Andar atual
  hasElevator  Boolean @default(false) // Tem elevador
  hasConcierge Boolean @default(false) // Tem porteiro

  // CaracterГғВӯsticas do imГғВіvel
  hasPool             Boolean @default(false) // Tem piscina
  hasGarden           Boolean @default(false) // Tem jardim
  hasBarbecue         Boolean @default(false) // Tem churrasqueira
  hasPlayground       Boolean @default(false) // Tem playground
  hasSecurity         Boolean @default(false) // Tem seguranГғВ§a
  hasAlarm            Boolean @default(false) // Tem alarme
  hasInternet         Boolean @default(false) // Tem internet
  hasCableTV          Boolean @default(false) // Tem TV a cabo
  hasGas              Boolean @default(false) // Tem gГғВЎs
  hasWater            Boolean @default(false) // Tem ГғВЎgua
  hasElectricity      Boolean @default(false) // Tem energia elГғВ©trica
  hasSewerage         Boolean @default(false) // Tem esgoto
  hasPhone            Boolean @default(false) // Tem telefone
  hasIntercom         Boolean @default(false) // Tem interfone
  hasParking          Boolean @default(false) // Tem estacionamento
  hasCoveredParking   Boolean @default(false) // Tem estacionamento coberto
  hasOpenParking      Boolean @default(false) // Tem estacionamento aberto
  hasDependent        Boolean @default(false) // Tem dependГғВӘncia
  hasServiceArea      Boolean @default(false) // Tem ГғВЎrea de serviГғВ§o
  hasKitchen          Boolean @default(false) // Tem cozinha
  hasBalcony          Boolean @default(false) // Tem varanda
  hasTerrace          Boolean @default(false) // Tem terraГғВ§o
  hasGourmetArea      Boolean @default(false) // Tem ГғВЎrea gourmet
  hasHomeOffice       Boolean @default(false) // Tem home office
  hasStorageRoom      Boolean @default(false) // Tem despensa
  hasLaundry          Boolean @default(false) // Tem lavanderia
  hasServiceEntrance  Boolean @default(false) // Tem entrada de serviГғВ§o
  hasWheelchairAccess Boolean @default(false) // Tem acessibilidade
  hasFireplace        Boolean @default(false) // Tem lareira
  hasAirConditioning  Boolean @default(false) // Tem ar condicionado
  hasHeating          Boolean @default(false) // Tem aquecimento
  hasSolarHeating     Boolean @default(false) // Tem aquecedor solar

  // Infraestrutura
  hasWaterTank           Boolean @default(false) // Tanque d'ГғВЎgua
  hasWell                Boolean @default(false) // PoГғВ§o
  hasArtesianWell        Boolean @default(false) // PoГғВ§o artesiano
  hasSepticTank          Boolean @default(false) // Fossa sГғВ©ptica
  hasRainwaterHarvesting Boolean @default(false) // CaptaГғВ§ГғВЈo de ГғВЎgua da chuva
  hasSolarPanels         Boolean @default(false) // PainГғВ©is solares
  hasWindTurbine         Boolean @default(false) // Turbina eГғВіlica
  hasPhotovoltaic        Boolean @default(false) // Fotovoltaico
  hasGeothermal          Boolean @default(false) // GeotГғВ©rmico
  hasBiomass             Boolean @default(false) // Biomassa
  hasCogeneration        Boolean @default(false) // CogeraГғВ§ГғВЈo
  hasMicrogrid           Boolean @default(false) // Microgrid
  hasSmartHome           Boolean @default(false) // Casa inteligente
  hasHomeAutomation      Boolean @default(false) // AutomaГғВ§ГғВЈo residencial

  // SeguranГғВ§a
  hasSecurityCameras  Boolean @default(false) // CГғВўmeras de seguranГғВ§a
  hasAccessControl    Boolean @default(false) // Controle de acesso
  hasBiometricAccess  Boolean @default(false) // Acesso biomГғВ©trico
  hasVideoIntercom    Boolean @default(false) // Interfone com vГғВӯdeo
  hasGateControl      Boolean @default(false) // Controle de portГғВЈo
  hasFence            Boolean @default(false) // Cerca
  hasWall             Boolean @default(false) // Muro
  hasGate             Boolean @default(false) // PortГғВЈo
  hasSecurityGuard    Boolean @default(false) // SeguranГғВ§a 24h
  hasSecurityDog      Boolean @default(false) // CГғВЈo de guarda
  hasSecurityLighting Boolean @default(false) // IluminaГғВ§ГғВЈo de seguranГғВ§a
  hasAlarmSystem      Boolean @default(false) // Sistema de alarme

  // SeguranГғВ§a contra incГғВӘndio
  hasSmokeDetector          Boolean? @default(false) // Detector de fumaГғВ§a
  hasCarbonMonoxideDetector Boolean? @default(false) // Detector de monГғВіxido de carbono
  hasFireExtinguisher       Boolean  @default(false) // Extintor de incГғВӘndio
  hasFirstAidKit            Boolean  @default(false) // Kit de primeiros socorros
  hasEmergencyExit          Boolean  @default(false) // SaГғВӯda de emergГғВӘncia
  hasFireAlarm              Boolean  @default(false) // Alarme de incГғВӘndio
  hasFireSprinkler          Boolean  @default(false) // Sprinkler
  hasFireHydrant            Boolean  @default(false) // Hidrante
  hasFireLadder             Boolean  @default(false) // Escada de incГғВӘndio
  hasFireHose               Boolean  @default(false) // Mangueira incГғВӘndio
  hasFireBlanket            Boolean  @default(false) // Cobertor incГғВӘndio

  // LocalizaГғВ§ГғВЈo
  address      String? // EndereГғВ§o completo
  neighborhood String? // Bairro
  city         String? // Cidade
  state        String? // Estado
  cep          String? // CEP
  latitude     Float? // Latitude
  longitude    Float? // Longitude
  location     Json? // Dados de localizaГғВ§ГғВЈo detalhados

  // Detalhes adicionais
  yearBuilt         Int? // Ano de construГғВ§ГғВЈo
  renovationYear    Int? // Ano de reforma
  furnished         Boolean @default(false) // Mobiliado
  semiFurnished     Boolean @default(false) // Semi mobiliado
  unfurnished       Boolean @default(false) // NГғВЈo mobiliado
  newConstruction   Boolean @default(false) // ConstruГғВ§ГғВЈo nova
  underConstruction Boolean @default(false) // Em construГғВ§ГғВЈo
  toBeBuilt         Boolean @default(false) // A ser construГғВӯdo

  // VisitaГғВ§ГғВЈo e disponibilidade
  availableForVisit   Boolean @default(true) // DisponГғВӯvel para visita
  visitSchedule       Json? // HorГғВЎrio de visita
  requiresAppointment Boolean @default(false) // Requer agendamento
  visitInstructions   String? // InstruГғВ§ГғВөes para visita

  // Documentos e legal
  registration     String? // MatrГғВӯcula do imГғВіvel
  registrationDate DateTime? // Data da matrГғВӯcula
  notary           String? // CartГғВіrio
  registry         String? // Registro
  condoName        String? // Nome do condomГғВӯnio
  condoRegistry    String? // Registro do condomГғВӯnio

  // Valores adicionais
  iptuValue     Decimal? // Valor do IPTU
  condoFee      Decimal? // Taxa de condomГғВӯnio
  iptuExemption Boolean  @default(false) // IsenГғВ§ГғВЈo de IPTU
  taxExemption  Boolean  @default(false) // IsenГғВ§ГғВЈo de taxas

  // ObservaГғВ§ГғВөes e informaГғВ§ГғВөes
  observations String? // ObservaГғВ§ГғВөes gerais
  restrictions String? // RestriГғВ§ГғВөes do imГғВіvel
  privileges   String? // PrivilГғВ©gios do imГғВіvel
  warnings     String? // Avisos importantes

  // Metadados
  views     Int? @default(0) // NГғВәmero de visualizaГғВ§ГғВөes
  favorites Int? @default(0) // NГғВәmero de favoritos
  shares    Int? @default(0) // NГғВәmero de compartilhamentos
  clicks    Int? @default(0) // NГғВәmero de cliques

  // Status e datas
  publishedAt DateTime? // Data de publicaГғВ§ГғВЈo
  expiresAt   DateTime? // Data de expiraГғВ§ГғВЈo
  featured    Boolean   @default(false) // ImГғВіvel em destaque
  priority    Int?      @default(0) // Prioridade de destaque

  // Relacionamentos multi-tenant
  organizationId String // Chave estrangeira para multi-tenant
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Modo Corretor e IA
  isFieldMode     Boolean   @default(false)
  fieldModeStatus String    @default("IDLE") // IDLE, ACTIVE, SYNCING, ERROR
  lastSyncedAt    DateTime?
  pendingChanges  Json? // Array de FieldModeChange
  priceSuggestion Json? // { suggestedPrice, confidence, marketAnalysis }
  saleProbability Json? // { probability, expectedDays, engagementScore }

  // Relacionamentos principais
  ownerId String? // ProprietГғВЎrio do imГғВіvel
  owner   Owner?  @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Relacionamentos secundГғВЎrios
  photos                 PropertyPhoto[] // Fotos do imГғВіvel
  versions               PropertyVersion[] // HistГғВіrico de alteraГғВ§ГғВөes
  leads                  Lead[] // Leads relacionados ao imГғВіvel
  announcements          Announcement[] // AnГғВәncios do imГғВіvel
  features               PropertyFeature[] // CaracterГғВӯsticas do imГғВіvel
  contracts              Contract[] // Contratos relacionados ao imГғВіvel
  propertyScores         PropertyScore[]
  propertyScoreHistories PropertyScoreHistory[]
  autoBlockRecords       AutoBlockRecord[]
  aiRecommendations      AIRecommendation[]
  integrationEvents      IntegrationEvent[]
  proofOfLifeRecords     ProofOfLife[]

  // ComentГғВЎrios
  /// Modelo principal de imГғВіveis com +80 campos detalhados
  /// Suporta todos os tipos de imГғВіveis e situaГғВ§ГғВөes
  /// Sistema de versionamento para histГғВіrico de alteraГғВ§ГғВөes
  /// IntegraГғВ§ГғВЈo com portais de imГғВіveis
  user            User?             @relation(fields: [userId], references: [id])
  userId          String?
  PropertyHistory PropertyHistory[]

  @@unique([code])
  // ГғпҝҪndices
  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@index([businessType])
  @@index([city])
  @@index([neighborhood])
  @@index([price])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([code])
}

/// Modelo de Fotos de ImГғВіveis
