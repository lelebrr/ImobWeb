/// Log de Auditoria para OperaГѓВ§ГѓВµes de Backup (LGPD)
model BackupLog {
  id           String   @id @default(cuid())
  backupId     String // ID externo ou da tarefa
  status       String // SUCCESS, FAILED, PENDING
  duration     Int? // DuraГѓВ§ГѓВЈo em ms
  size         Int? // Tamanho em bytes
  errorMessage String? // Mensagem de erro se houver
  type         String // FULL, INCREMENTAL, RESTORE
  executedAt   DateTime @default(now())

  @@index([backupId])
  @@index([status])
}

/// Modelo de Contratos
model Contract {
  id              String    @id @default(cuid())
  templateId      String?
  type            String // sale, rent, proposal, authorization, commercial
  status          String // draft, pending_review, etc.
  title           String
  description     String?   @db.Text
  totalValue      Decimal?  @db.Decimal(15, 2)
  installments    Int?
  startDate       DateTime?
  endDate         DateTime?
  expiresAt       DateTime?
  signedAt        DateTime?
  documentUrl     String?
  documentVersion Int       @default(1)
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  // Relacionamentos
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyId      String?
  property        Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  parties         ContractParty[]
  clauses         ContractClause[]
  contractHistory ContractHistory[]
  billingRule     BillingRule?
  invoices        Invoice[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([type])
  @@index([status])
}

/// Partes envolvidas no contrato
model ContractParty {
  id                String    @id @default(cuid())
  contractId        String
  contract          Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type              String // buyer, seller, tenant, landlord, witness, guarantor
  name              String
  document          String
  documentType      String // cpf, cnpj, rg
  email             String
  phone             String
  address           String?
  status            String    @default("pending") // pending, sent, viewed, signed, etc.
  signedAt          DateTime?
  signatureImageUrl String?
  biometricFaceUrl  String?
  biometricVerified Boolean   @default(false)
  ipAddress         String?
  userAgent         String?
  signingToken      String?   @unique @default(cuid())

  @@index([contractId])
}

/// ClГѓВЎusulas do contrato
model ContractClause {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  order      Int
  required   Boolean  @default(true)
  custom     Boolean  @default(false)

  @@index([contractId])
}

/// Modelo de HistГѓВіrico de Propriedades (VersГѓВЈo Simples de Snapshot)
model PropertyHistory {
  id         String   @id @default(cuid())
  propertyId String
  snapshot   Json // Dados completos do imГѓВіvel no momento
  changeType String // PRICE_CHANGE, STATUS_CHANGE, etc.
  changedBy  String // ID do usuГѓВЎrio
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

/// Modelo de HistГѓВіrico de Contratos
model ContractHistory {
  id         String   @id @default(cuid())
  contractId String
  version    Int // NГѓВєmero da versГѓВЈo (1, 2, 3...)
  snapshot   Json // ConteГѓВєdo do contrato, valores, etc.
  reason     String? // Motivo da alteraГѓВ§ГѓВЈo
  changedBy  String // ID do usuГѓВЎrio
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

/// Modelo de Logs de ImportaГ§ГЈo
model ImportLog {
  id        String   @id @default(cuid())
  status    String   @default("pending") // completed, failed, syncing, pending
  message   String?
  totalRows Int      @default(0)
  imported  Int      @default(0)
  updated   Int      @default(0)
  skipped   Int      @default(0)
  errors    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Modelo de Resultados de ImportaГ§ГЈo
model ImportResult {
  id        String   @id @default(cuid())
  userId    String? // ID do usuГЎrio que realizou a importaГ§ГЈo
  status    String? // completed, failed
  result    String?  @db.Text // JSON snapshot da importaГ§ГЈo
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Modelo de Eventos de IntegraГ§ГЈo
model IntegrationEvent {
  id             String       @id @default(cuid())
  organizationId String // Chave estrangeira para multi-tenant
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  portalId   String // ID do portal (zap, vivareal, etc.)
  action     String // AГ§ГЈo realizada (CREATE, UPDATE, SYNC, etc.)
  status     String // Status da operaГ§ГЈo (SUCCESS, ERROR, PENDING, etc.)
  message    String? // Mensagem descritiva
  metadata   Json? // Metadados adicionais
  propertyId String? // ID do imГіvel relacionado
  timestamp  DateTime @default(now())

  // Relacionamentos
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([portalId])
  @@index([action])
  @@index([status])
  @@index([timestamp])
  @@index([propertyId])
}

// ============================================
// IA 5 - COMUNICAГ‡ГѓO (EMAIL & SMS)
// ============================================

/// Modelo de Uso de ComunicaГ§ГЈo (Individual)
model CommunicationUsage {
  id          String              @id @default(cuid())
  type        CommunicationType
  status      CommunicationStatus @default(PENDENTE)
  recipient   String // E-mail ou Telefone
  subject     String? // Para e-mails
  content     String?             @db.Text
  externalId  String?             @unique // ID do Mailchimp/Mandrill
  cost        Decimal?            @db.Decimal(10, 4) // Valor em R$
  metadata    Json? // Dados extras (tracking, tags, etc)
  sentAt      DateTime?           @default(now())
  deliveredAt DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  error       String?

  // Relacionamentos
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String? // UsuГЎrio que disparou
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([externalId])
}

/// Modelo de Cotas de ComunicaГ§ГЈo por OrganizaГ§ГЈo
model CommunicationQuota {
  id        String            @id @default(cuid())
  type      CommunicationType
  limit     Int               @default(0) // Limite mensal (X envios)
  used      Int               @default(0) // Envios realizados no mГЄs
  resetDate DateTime // PrГіxima data de reset (geralmente renovaГ§ГЈo do plano)

  // Detalhes financeiros para Master Admin
  estimatedCost Decimal @default(0) @db.Decimal(15, 2)
  totalRevenue  Decimal @default(0) @db.Decimal(15, 2) // Caso o plano tenha valor especГ­fico para isso

  // Relacionamentos
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, type])
  @@index([organizationId])
  @@index([type])
}

// ============================================
// IA 6 - FINANCEIRO (SPLIT INTELIGENTE)
// ============================================

/// Regras de Split para Contratos de Aluguel
model BillingRule {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  agencyPercent Decimal  @default(10.0) @db.Decimal(5, 2)
  ownerPercent  Decimal  @default(90.0) @db.Decimal(5, 2)
  fixedFee      Decimal? @db.Decimal(15, 2) // Taxa fixa se houver

  startDate DateTime @default(now())
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// CobranГѓВ§as Mensais (Aluguel)
model Invoice {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  amount         Decimal   @db.Decimal(15, 2)
  dueDate        DateTime
  status         String    @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  paymentMethod  String? // PIX, BOLETO, CARD
  paidAt         DateTime?
  referenceMonth String? // ex: "04/2026"

  distributions FinancialDistribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([status])
  @@index([dueDate])
}

/// DistribuiГѓВ§ГѓВЈo de Valores (Split)
model FinancialDistribution {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  recipientType String // AGENCY, OWNER, THIRD_PARTY
  recipientName String
  recipientId   String? // User ID or third party ID

  amount       Decimal   @db.Decimal(15, 2)
  status       String    @default("PENDING") // PENDING, PAID (D+1/D+5)
  scheduledFor DateTime? // Data prevista de repasse

  metadata Json? // Dados bancГѓВЎrios ou logs de conciliaГѓВ§ГѓВЈo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([recipientType])
  @@index([status])
}

// ============================================
// RELATГ“RIOS DIГЃRIOS DE INTEGRAГ‡ГѓO
// ============================================

model DailyReport {
  id             String   @id @default(cuid())
  organizationId String?
  date           DateTime @default(now())
  report         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([date])
}

// ============================================
// SCORE DE SAГљDE DOS IMГ“VEIS (PROMPT 3/9)
// ============================================

/// NГ­vel de saГєde do imГіvel
enum HealthLevel {
  healthy // 80-100
  warning // 50-79
  critical // 0-49
}

/// Score atual do imГіvel
model PropertyScore {
  id                String      @id @default(cuid())
  propertyId        String      @unique
  overallScore      Int // 0-100
  healthLevel       HealthLevel
  factors           Json // Array de FactorDetail
  calculatedAt      DateTime
  nextCalculationAt DateTime
  isRealTime        Boolean     @default(false)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([healthLevel])
  @@index([calculatedAt])
}

/// HistГіrico de scores do imГіvel (tendГЄncias)
model PropertyScoreHistory {
  id           String      @id @default(cuid())
  propertyId   String
  overallScore Int
  healthLevel  HealthLevel
  factors      Json // Array de FactorDetail
  calculatedAt DateTime
  trigger      String // scheduled, manual, update, alert

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([calculatedAt])
  @@index([trigger])
}

/// ConfiguraГ§Гµes de Bloqueio AutomГЎtico
model AutoBlockConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  enabled                  Boolean @default(false)
  daysWithoutOwnerResponse Int     @default(30)
  daysBeforeNotification   Int     @default(3)
  notifyOnBlock            Boolean @default(true)
  blockFromPortals         Boolean @default(true)
  keepOnPlatform           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Registro de bloqueios automГЎticos
model AutoBlockRecord {
  id                 String    @id @default(cuid())
  propertyId         String
  reason             String // no_owner_response, price_not_updated, photos_outdated, manual
  blockedAt          DateTime
  unblockedAt        DateTime?
  isActive           Boolean   @default(true)
  notifySent         Boolean   @default(false)
  notificationSentAt DateTime?
  metadata           Json?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([isActive])
  @@index([blockedAt])
}

/// RecomendaГ§Гµes da IA para melhorar score
model AIRecommendation {
  id                 String    @id @default(cuid())
  propertyId         String
  type               String // update_photos, adjust_price, update_description, contact_owner, check_portal_rules, refresh_announcement
  priority           String // high, medium, low
  message            String
  potentialScoreGain Int
  actionUrl          String?
  isRead             Boolean   @default(false)
  isActioned         Boolean   @default(false)
  actionedAt         DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([priority])
  @@index([isRead])
}

// ============================================
// MODELOS DE ONBOARDING E MГ‰TRICAS DE ADOГ‡ГѓO
// ============================================

/// Modelo de Progresso de Onboarding
model OnboardingProgress {
  id             String       @id @default(cuid())
  userId         String       @unique
  organizationId String
  userType       String // Corretor AutГґnomo, ImobiliГЎria Pequena, Rede de Franquias
  completedItems Json? // Array de IDs de itens concluГ­dos
  currentStep    Int          @default(0)
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  lastActivityAt DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([userType])
}

/// Modelo de MГ©tricas de AdoГ§ГЈo
model AdoptionMetrics {
  id                                 String       @id @default(cuid())
  organizationId                     String
  period                             String // Formato: YYYY-WXX ou YYYY-MM
  onboardingCompletionRate           Float // Percentual (0-100)
  keyFeatureUsageRate                Float // Percentual (0-100)
  averageTimeToFirstPublication      Float // Em horas
  lowHealthScorePropertiesPercentage Float // Percentual (0-100)
  totalUsers                         Int
  activeUsers                        Int // Logins nos Гєltimos 7 dias
  createdAt                          DateTime     @default(now())
  updatedAt                          DateTime     @updatedAt
  organization                       Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, period])
}

// ============================================
// IA - PROVA DE VIDA
// ============================================

/// Modelo de Prova de Vida
model ProofOfLife {
  id                 String    @id @default(cuid())
  propertyId         String
  ownerContact       Json // { name, phone, whatsapp }
  lastProofDate      DateTime
  proofType          String // VIDEO, PHOTO, DOCUMENT
  proofContent       String
  verificationStatus String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  verificationDate   DateTime?
  aiAnalysis         Json // { confidence, riskScore, recommendations, detailedAnalysis }
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  property           Property  @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([verificationStatus])
  @@index([createdAt])
}

// ============================================
// PUBLICAГ‡ГѓO EM MГљLTIPLOS PORTAIS (DETALHADO)
// ============================================

model Publication {
  id             String            @id @default(cuid())
  propertyId     String            @unique
  organizationId String
  packageId      String
  status         PublicationStatus @default(DRAFT)
  publishedAt    DateTime?
  expiresAt      DateTime?
  lastSyncAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  package        PublicationPackage @relation(fields: [packageId], references: [id])
  announcements  PropertyAnnouncement[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
}

model PublicationPackage {
  id             String                 @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           PublicationPackageType @default(BASIC)
  portals        Json?
  durationDays   Int                    @default(30)
  isHighlight    Boolean                @default(false)
  highlightLevel HighlightLevel          @default(NONE)
  price          Decimal                @default(0)
  isActive       Boolean                @default(true)
  isDefault      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  publications   Publication[]

  @@index([organizationId])
  @@index([isActive])
  @@index([isDefault])
}

model PropertyAnnouncement {
  id            String       @id @default(cuid())
  publicationId String
  portalId      String
  portalName    String
  portalType    String?
  externalId    String?      @unique
  status        PortalStatus @default(NOT_PUBLISHED)
  url           String?
  errorMessage  String?
  publishedAt   DateTime?
  lastSyncAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publication   Publication  @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, portalId])
  @@index([publicationId])
  @@index([portalId])
  @@index([status])
}

// ============================================
// ENUMS ADICIONAIS
// ============================================

enum PublicationStatus {
  DRAFT
  PUBLISHING
  PUBLISHED
  SYNCING
  ERROR
  BLOCKED
  EXPIRED
}

enum PortalStatus {
  NOT_PUBLISHED
  PENDING
  PUBLISHED
  ERROR
  BLOCKED
  DELETED
}

enum PublicationPackageType {
  BASIC
  HIGHLIGHT
  SUPER_HIGHLIGHT
  PREMIUM
  CUSTOM
}

enum PublicationLogType {
  CREATE
  UPDATE
  DELETE
  REPUBLISH
  SYNC
}

enum HighlightLevel {
  NONE
  STANDARD
  PREMIUM
  PREMIUM_PLUS
  DESTAQUE
  SUPER_DESTAQUE
}

// ============================================
// PARTNER & WHITE LABEL SYSTEM
// ============================================

model Partner {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  tier                String   // reseller, franchise
  level               String   // silver, gold, platinum, franchise
  parentId            String?
  status              String   @default("active")
  commissionRate      Decimal  @db.Decimal(5, 2)
  recurringCommission Boolean  @default(true)
  maxSubAccounts      Int
  brandingConfigId    String?  @unique
  brandingConfig      BrandingConfig? @relation(fields: [brandingConfigId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  resellerClients ResellerClient[]
  commissions     Commission[]
  addons          PartnerAddon[]

  @@index([email])
}

model BrandingConfig {
  id                   String   @id @default(cuid())
  partnerId            String   @unique
  domain               String   @unique
  logoUrl              String?
  faviconUrl           String?
  primaryColor         String
  secondaryColor       String
  backgroundColor      String
  textColor            String
  accentColor          String
  fontFamily           String
  darkModeEnabled      Boolean  @default(true)
  darkModeColors       Json?    // { primary, secondary, background, text, accent }
  hidePlatformBranding Boolean  @default(false)
  customCss            String?
  customJs             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  partner              Partner?
}

model ResellerClient {
  id              String   @id @default(cuid())
  partnerId       String
  partner         Partner  @relation(fields: [partnerId], references: [id])
  subAccountId    String   @unique
  subAccount      Organization @relation(fields: [subAccountId], references: [id])
  clientName      String
  clientDomain    String
  status          String   @default("active")
  monthlyValue    Decimal  @db.Decimal(15, 2)
  commissionRate  Decimal  @db.Decimal(5, 2)
  commissionValue Decimal  @db.Decimal(15, 2)
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  commissions     Commission[]

  @@index([partnerId])
  @@index([subAccountId])
}

model Commission {
  id               String   @id @default(cuid())
  partnerId        String
  partner          Partner  @relation(fields: [partnerId], references: [id])
  resellerClientId String
  resellerClient   ResellerClient @relation(fields: [resellerClientId], references: [id])
  amount           Decimal  @db.Decimal(15, 2)
  period           String   // YYYY-MM
  status           String   @default("pending") // pending, paid, cancelled
  calculatedAt     DateTime @default(now())
  paidAt           DateTime?
  createdAt        DateTime @default(now())

  @@index([partnerId])
  @@index([resellerClientId])
  @@index([period])
}

model Addon {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(15, 2)
  billingType  String   @default("monthly") // monthly, yearly, once, usage
  usageBased   Boolean  @default(false)
  usagePrice   Decimal? @db.Decimal(15, 2)
  icon         String?
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  partnerAddons PartnerAddon[]
}

model PartnerAddon {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id])
  addonId     String
  addon       Addon    @relation(fields: [addonId], references: [id])
  isActive    Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([partnerId])
  @@index([addonId])
}

model PropertyView {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  count      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
}
