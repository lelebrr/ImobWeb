// ============================================
// MODELOS DE ONBOARDING E MÉTRICAS DE ADOÇÃO (NOVOS)
// ============================================

/// Modelo de Progresso de Onboarding
model OnboardingProgress {
  id            String   @id @default(cuid())
  userId        String   @unique
  agencyId      String
  userType      String   // Corretor Autônomo, Imobiliária Pequena, Rede de Franquias
  completedItems Json?   // Array de IDs de itens concluídos
  currentStep   Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  lastActivityAt DateTime @updatedAt

  // Relacionamentos
  user          User     @relation(fields: [userId], references: [id])
  agency        Organization @relation(fields: [agencyId], references: [id])

  @@index([userId])
  @@index([agencyId])
  @@index([userType])
}

/// Modelo de Métricas de Adoção
model AdoptionMetrics {
  id                        String   @id @default(cuid())
  agencyId                  String
  period                    String   // Formato: YYYY-WXX (ano-semana) ou YYYY-MM (ano-mês)
  onboardingCompletionRate  Float    // Percentual (0-100)
  keyFeatureUsageRate       Float    // Percentual (0-100)
  averageTimeToFirstPublication Float // Em horas
  lowHealthScorePropertiesPercentage Float // Percentual (0-100)
  totalUsers                Int
  activeUsers               Int      // Logins nos últimos 7 dias
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relacionamentos
  agency Organization @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
  @@index([period])
  @@index([agencyId, period], unique)
}

