/// Modelo de HistГғВіrico de Pagamentos
model PaymentHistory {
  id             String        @id @default(cuid())
  subscriptionId String // ID da assinatura
  amount         Decimal // Valor do pagamento
  paymentMethod  PaymentMethod // MГғВ©todo de pagamento
  status         String        @default("pending") // Status do pagamento
  transactionId  String? // ID da transaГғВ§ГғВЈo
  invoiceId      String? // ID da fatura
  description    String? // DescriГғВ§ГғВЈo do pagamento
  metadata       Json? // Metadados adicionais
  processedAt    DateTime? // Data de processamento
  createdAt      DateTime      @default(now()) // Data de criaГғВ§ГғВЈo
  updatedAt      DateTime      @updatedAt // Data de atualizaГғВ§ГғВЈo

  // Relacionamentos
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // ComentГғВЎrios
  /// HistГғВіrico completo de pagamentos
  /// Suporte a mГғВәltiplos mГғВ©todos de pagamento
  /// Rastreabilidade de transaГғВ§ГғВөes

  // ГғпҝҪndices
  @@index([subscriptionId])
  @@index([status])
  @@index([paymentMethod])
  @@index([transactionId])
  @@index([createdAt])
}

/// Modelo de NotificaГғВ§ГғВөes
model Notification {
  id        String           @id @default(cuid())
  title     String // TГғВӯtulo da notificaГғВ§ГғВЈo
  message   String // Mensagem da notificaГғВ§ГғВЈo
  type      NotificationType // Tipo de notificaГғВ§ГғВЈo
  status    String           @default("unread") // Status da notificaГғВ§ГғВЈo
  userId    String // ID do usuГғВЎrio
  metadata  Json? // Metadados adicionais
  readAt    DateTime? // Data de leitura
  createdAt DateTime         @default(now()) // Data de criaГғВ§ГғВЈo
  updatedAt DateTime         @updatedAt // Data de atualizaГғВ§ГғВЈo

  // Relacionamentos
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ComentГғВЎrios
  /// Sistema de notificaГғВ§ГғВөes do plataforma
  /// Diferentes tipos de notificaГғВ§ГғВөes
  /// Sistema de leitura e status

  // ГғпҝҪndices
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([readAt])
}

/// Modelo de CaracterГғВӯsticas Personalizadas de ImГғВіveis
model PropertyFeature {
  id         String   @id @default(cuid())
  propertyId String // ID do imГғВіvel
  name       String // Nome da caracterГғВӯstica
  value      String // Valor da caracterГғВӯstica
  category   String? // Categoria da caracterГғВӯstica
  order      Int      @default(0) // Ordem de exibiГғВ§ГғВЈo
  isActive   Boolean  @default(true) // EstГғВЎ ativa
  createdAt  DateTime @default(now()) // Data de criaГғВ§ГғВЈo
  updatedAt  DateTime @updatedAt // Data de atualizaГғВ§ГғВЈo

  // Relacionamentos
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // ComentГғВЎrios
  /// CaracterГғВӯsticas personalizadas de imГғВіveis
  /// Sistema de categorizaГғВ§ГғВЈo e ordenaГғВ§ГғВЈo
  /// Extensibilidade do sistema de caracterГғВӯsticas

  // ГғпҝҪndices
  @@index([propertyId])
  @@index([category])
  @@index([name])
  @@index([order])
}

// ============================================
// IA 4 - AUDIT LOG (SEGURANГғвҖЎA ENTERPRISE)
// ============================================

/// Tipo de aГғВ§ГғВЈo auditada
enum AuditAction {
  CREATE // CriaГғВ§ГғВЈo de registro
  UPDATE // AtualizaГғВ§ГғВЈo de registro
  DELETE // ExclusГғВЈo de registro
  READ // Leitura de registro
  LOGIN // Login de usuГғВЎrio
  LOGOUT // Logout de usuГғВЎrio
  SEARCH // Pesquisa de dados
  ACCESS // Acesso a recurso sensГғВӯvel
  EXPORT // ExportaГғВ§ГғВЈo de dados
  IMPORT // ImportaГғВ§ГғВЈo de dados
  PUBLISH // PublicaГғВ§ГғВЈo (ex: portais)
  REVOKE // RevogaГғВ§ГғВЈo de acesso
  APPROVE // AprovaГғВ§ГғВЈo
  REJECT // RejeiГғВ§ГғВЈo
  SEND // Envio de mensagem
  RECEIVE // Recebimento de mensagem
  PASSWORD_CHANGE // AlteraГғВ§ГғВЈo de senha
  SETTINGS_CHANGE // AlteraГғВ§ГғВЈo de configuraГғВ§ГғВөes
}

/// Entidade auditada
enum AuditEntity {
  USER // UsuГғВЎrio
  ORGANIZATION // OrganizaГғВ§ГғВЈo
  PROPERTY // ImГғВіvel
  LEAD // Lead
  OWNER // ProprietГғВЎrio
  CONVERSATION // Conversa
  ANNOUNCEMENT // AnГғВәncio
  PACKAGE // Pacote
  SUBSCRIPTION // Assinatura
  PAYMENT // Pagamento
  NOTIFICATION // NotificaГғВ§ГғВЈo
}

/// NГғВӯvel de risco da aГғВ§ГғВЈo
enum AuditRiskLevel {
  LOW // Baixo risco
  MEDIUM // MГғВ©dio risco
  HIGH // Alto risco
  CRITICAL // Risco crГғВӯtico
}

/// Modelo de Auditoria (AuditLog)
model AuditLog {
  id String @id @default(cuid())

  // IdentificaГғВ§ГғВЈo da aГғВ§ГғВЈo
  action     AuditAction // Tipo de aГғВ§ГғВЈo realizada
  entityType String? // Tipo da entidade afetada (Property, Lead, User)
  entityId   String? // ID do registro afetado

  // Dados da aГғВ§ГғВЈo
  beforeValues Json? // Estado anterior
  afterValues  Json? // Estado posterior
  diff         Json? // DiferenГғВ§a entre estados
  metadata     Json? // Metadados adicionais
  description  String? // DescriГғВ§ГғВЈo da aГғВ§ГғВЈo

  // Contexto de seguranГғВ§a
  ipAddress String? // EndereГғВ§o IP do usuГғВЎrio
  userAgent String? // User Agent do navegador
  sessionId String? // ID da sessГғВЈo

  // ClassificaГғВ§ГғВЈo de risco
  riskLevel   AuditRiskLevel @default(LOW)
  containsPII Boolean        @default(false) // ContГғВ©m dados pessoais
  isSensitive Boolean        @default(false) // ContГғВ©m dados sensГғВӯveis

  // Relacionamentos
  userId         String? // UsuГғВЎrio que realizou a aГғВ§ГғВЈo
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String? // OrganizaГғВ§ГғВЈo relacionada
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Timestamps
  timestamp DateTime @default(now()) // Quando ocorreu
  createdAt DateTime @default(now())

  // ГғпҝҪndiices para performance
  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([timestamp])
  @@index([riskLevel])
  @@index([entityType, entityId])
}

