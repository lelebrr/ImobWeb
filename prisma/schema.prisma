  title       String // TГғВӯtulo do anГғВәncio
  description String? // DescriГғВ§ГғВЈo do anГғВәncio
  url         String? // URL do anГғВәncio no portal
  externalId  String? // ID externo do anГғВәncio
  status      AnnouncementStatus @default(RASCUNHO) // Status do anГғВәncio
  portalType  PortalType // Tipo de portal
  publishedAt DateTime? // Data de publicaГғВ§ГғВЈo
  expiresAt   DateTime? // Data de expiraГғВ§ГғВЈo
  views       Int?               @default(0) // VisualizaГғВ§ГғВөes
  clicks      Int?               @default(0) // Cliques
  likes       Int?               @default(0) // Curtidas
  shares      Int?               @default(0) // Compartilhamentos
  price       Decimal? // PreГғВ§o no portal
  currency    String?            @default("BRL") // Moeda
  lastSync    DateTime? // ГғЕЎltima sincronizaГғВ§ГғВЈo
  syncErrors  Json? // Erros de sincronizaГғВ§ГғВЈo
  metadata    Json? // Metadados adicionais
