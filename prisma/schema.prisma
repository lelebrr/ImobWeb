// ============================================
// SCHEMA PRISMA - CRM IMOBILIГѓпїЅRIO IMOBWEB
// ============================================
// Arquitetura multi-tenant com organizaГѓВ§ГѓВЈo (imobiliГѓВЎria)
// Suporte a integraГѓВ§ГѓВµes com portais de imГѓВіveis
// Sistema de conversas WhatsApp com IA
// GestГѓВЈo completa de leads e proprietГѓВЎrios
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

/// Status geral de entidades
enum EntityStatus {
  ATIVO // Entidade ativa no sistema
  INATIVO // Entidade desativada
  ARQUIVADO // Entidade arquivada (nГѓВЈo mais em uso)
}

/// Status de imГѓВіvel
enum PropertyStatus {
  DISPONIVEL // ImГѓВіvel disponГѓВ­vel para venda/locaГѓВ§ГѓВЈo
  VENDIDO // ImГѓВіvel vendido
  ALUGADO // ImГѓВіvel alugado
  RESERVADO // ImГѓВіvel reservado
  DESATUALIZADO // ImГѓВіvel com dados desatualizados
  SUSPENSO // ImГѓВіvel suspenso por pendГѓВЄncias
  RASCUNHO // ImГѓВіvel em rascunho (nГѓВЈo publicado)
}

/// Tipo de imГѓВіvel
enum PropertyType {
  APARTAMENTO // Apartamento
  CASA // Casa
  TERRENO // Terreno
  COMERCIAL // ImГѓВіvel comercial
  COMERCIAL_LOJA // Loja comercial
  COMERCIAL_GARAGEM // Garagem comercial
  COMERCIAL_LOTE // Lote comercial
  COMERCIAL_OUTRO // Outro comercial
  SITIO // SГѓВ­tio
  CHACARA // ChГѓВЎcara
  FAZENDA // Fazenda
  CONDOMINIO // CondomГѓВ­nio fechado
  GARAGEM // Garagem
  CABINE // Cabine
  QUADRA // Quadra
  TERRENO_RESIDENCIAL // Terreno residencial
  SITIO_RESIDENCIAL // SГѓВ­tio residencial
  CHACARA_RESIDENCIAL // ChГѓВЎcara residencial
  OUTRO // Outro tipo
}

/// Tipo de negГѓВіcio
enum BusinessType {
  VENDA // Venda
  LOCACAO // LocaГ§ГЈo
  VENDA_LOCACAO // Venda e locaГ§ГЈo
}

/// SituaГѓВ§ГѓВЈo do imГѓВіvel
enum PropertySituation {
  NOVO // ImГѓВіvel novo
  SEM_NOVO // ImГѓВіvel usado
  NA_MAO // ImГѓВіvel na mГѓВЈo
  EM_CONSTRUCAO // Em construГѓВ§ГѓВЈo
  TERMINADO // Terminado
}

/// SituaГѓВ§ГѓВЈo do proprietГѓВЎrio
enum OwnerSituation {
  DISPONIVEL // DisponГѓВ­vel para contato
  OCULTO // Oculto no sistema
  INATIVO // Inativo
  VENDIDO // JГѓВЎ vendeu
  ALUGADO // JГѓВЎ alugou
}

/// Status do lead
enum LeadStatus {
  NOVO // Lead novo
  CONTATADO // JГѓВЎ foi contatado
  INTERESSADO // Mostrou interesse
  AGUARDANDO // Aguardando resposta
  PERDIDO // Lead perdido
  CONVERTIDO // Lead convertido (comprador/locador)
  ARQUIVADO // Lead arquivado
}

/// Status da conversa
enum ConversationStatus {
  ATIVA // Conversa ativa
  INATIVA // Conversa inativa
  RESOLVIDA // Conversa resolvida
  ENCERRADA // Conversa encerrada
  ENVIADO // Mensagem enviada
  ENTREGUE // Mensagem entregue
  LIDA // Mensagem lida
  ERRO // Erro no envio
}

/// Status do anГѓВєncio
enum AnnouncementStatus {
  RASCUNHO // AnГѓВєncio em rascunho
  PUBLICADO // AnГѓВєncio publicado
  ATIVO // AnГѓВєncio ativo
  INATIVO // AnГѓВєncio inativo
  SUSPENSO // AnГѓВєncio suspenso
  EXPIRADO // AnГѓВєncio expirado
  RENOVADO // AnГѓВєncio renovado
}

/// Status do pacote
enum PackageStatus {
  ATIVO // Pacote ativo
  INATIVO // Pacote inativo
  EXPIRADO // Pacote expirado
  CANCELADO // Pacote cancelado
}

/// Tipo de plano
enum PackageType {
  BASICO // Plano bГѓВЎsico
  DESTAQUE // Plano destaque
  PREMIUM // Plano premium
  CORPORATIVO // Plano corporativo
  CUSTOMIZADO // Plano customizado
}

/// Status da integraГѓВ§ГѓВЈo com portal
enum PortalIntegrationStatus {
  ATIVO // IntegraГѓВ§ГѓВЈo ativa
  INATIVO // IntegraГѓВ§ГѓВЈo inativa
  SUSPENSO // IntegraГѓВ§ГѓВЈo suspensa
  ERRO // Erro na integraГѓВ§ГѓВЈo
}

/// Tipo de portal
enum PortalType {
  ZAP
  VIVAREAL
  OLX
  IMOVELWEB
  CHAVES_NA_MAO
  VRSYNC
  CUSTOM
}

/// Tipo de comunicaГ§ГЈo
enum CommunicationType {
  EMAIL
  SMS
}

/// Status do envio de comunicaГ§ГЈo
enum CommunicationStatus {
  PENDENTE
  ENVIADO
  ENTREGUE
  LIDO
  FALHOU
  CANCELADO
}

/// Tipo de usuГѓВЎrio
enum UserRole {
  // Roles de Plataforma (Equipe ImobWeb)
  PLATFORM_MASTER // Super Admin com acesso total
  PLATFORM_MARKETING // Marketing da plataforma
  PLATFORM_FINANCE // Financeiro da plataforma
  PLATFORM_SUPPORT // Suporte da plataforma

  // Roles de AgГЄncia (ImobiliГЎria)
  AGENCY_MASTER // Dono/Administrador da ImobiliГЎria
  AGENCY_SALES // Corretor / Vendas
  AGENCY_HR // RH / GestГЈo de Equipe
  AGENCY_MARKETING // Marketing da ImobiliГЎria
  AGENCY_FINANCE // Financeiro da ImobiliГЎria
  AGENCY_SUPPORT // Suporte da ImobiliГЎria

  // Legado (Para compatibilidade/MigraГ§ГЈo)
  ADMIN
  GERENTE
  CORRETOR
  ASSISTENTE
}

/// Tipo de notificaГѓВ§ГѓВЈo
enum NotificationType {
  INFO // InformaГѓВ§ГѓВЈo geral
  WARNING // Aviso importante
  ERROR // Erro do sistema
  SUCCESS // Sucesso operacional
  LEAD // NotificaГѓВ§ГѓВЈo de lead
  PROPERTY // NotificaГѓВ§ГѓВЈo de imГѓВіvel
  PAYMENT // NotificaГѓВ§ГѓВЈo de pagamento
  SYSTEM // NotificaГѓВ§ГѓВЈo do sistema
}

/// Tipo de mГѓВ©todo de pagamento
enum PaymentMethod {
  CREDIT_CARD // CartГѓВЈo de crГѓВ©dito
  DEBIT_CARD // CartГѓВЈo de dГѓВ©bito
  BOLETO // Boleto bancГѓВЎrio
  PIX // PIX
  TRANSFER // TransferГѓВЄncia bancГѓВЎria
  CASH // Dinheiro
}

/// DireГѓВ§ГѓВЈo da mensagem WhatsApp
enum MessageDirection {
  INCOMING // Mensagem recebida
  OUTGOING // Mensagem enviada
}

/// Fonte do lead
enum LeadSource {
  WEBSITE // Site da imobiliГѓВЎria
  PORTAL // Portal de imГѓВіveis
  INDICATION // IndicaГѓВ§ГѓВЈo
  REFERRAL // IndicaГѓВ§ГѓВЈo de cliente
  SOCIAL // Rede social
  PHONE // Telefone direto
  WALK_IN // Cliente que chegou na loja
  OTHER // Outra fonte
}

// ============================================
// MODELOS PRINCIPAIS
// ============================================

/// Modelo de UsuГѓВЎrios do Sistema (Corretores, Gerentes, Admin)
model User {
  id             String       @id @default(cuid())
  name           String // Nome completo do usuГѓВЎrio
  email          String       @unique // Email ГѓВєnico para login
  phone          String? // Telefone de contato
  whatsapp       String? // WhatsApp para contato profissional
  password       String // Senha criptografada
  role           UserRole // Papel do usuГѓВЎrio no sistema
  permissions    Json? // Overrides de permissГЈo por usuГЎrio (ex: { "denied": ["billing:view"] })
  status         EntityStatus @default(ATIVO) // Status do usuГѓВЎrio
  lastLogin      DateTime? // ГѓЕЎltimo login do usuГѓВЎrio
  avatar         String? // URL do avatar do usuГѓВЎrio
  bio            String? // Biografia ou descriГѓВ§ГѓВЈo do usuГѓВЎrio
  department     String? // Departamento ou ГѓВЎrea de atuaГѓВ§ГѓВЈo
  specialization String? // EspecializaГѓВ§ГѓВЈo do usuГѓВЎrio
  createdAt      DateTime     @default(now()) // Data de criaГѓВ§ГѓВЈo
  updatedAt      DateTime     @updatedAt // Data de atualizaГѓВ§ГѓВЈo

  // Relacionamentos
  organizationId String // Chave estrangeira para multi-tenant
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relacionamentos com entidades principais
  properties         Property[] // ImГѓВіveis criados/gerenciados pelo usuГѓВЎrio
  leads              Lead[] // Leads atribuГѓВ­dos ao usuГѓВЎrio
  conversations      Conversation[] // Conversas do usuГѓВЎrio
  notifications      Notification[] // NotificaГѓВ§ГѓВµes do usuГѓВЎrio
  assignedLeads      Lead[]               @relation("AssignedLeads") // Leads atribuГѓВ­dos explicitamente
  auditLogs          AuditLog[]
  communicationUsage CommunicationUsage[]
  onboardingProgress OnboardingProgress?

  // ComentГѓВЎrios
  /// UsuГѓВЎrio do sistema com diferentes nГѓВ­veis de permissГѓВЈo
  /// Suporta multi-tenant atravГѓВ©s da organizaГѓВ§ГѓВЈo
  propertyVersions PropertyVersion[]

  // ГѓпїЅndices
  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@index([whatsapp])
}

/// Modelo de OrganizaГѓВ§ГѓВµes (Multi-tenant - ImobiliГѓВЎrias)
model Organization {
  id             String       @id @default(cuid())
  name           String // Nome da imobiliГѓВЎria
  cnpj           String?      @unique // CNPJ ГѓВєnico
  phone          String? // Telefone principal
  email          String?      @unique // Email corporativo
  website        String? // Website da imobiliГѓВЎria
  logo           String? // URL do logo da empresa
  address        String? // EndereГѓВ§o completo
  neighborhood   String? // Bairro
  city           String? // Cidade
  state          String? // Estado
  cep            String? // CEP
  country        String?      @default("Brasil") // PaГѓВ­s
  status         EntityStatus @default(ATIVO) // Status da organizaГѓВ§ГѓВЈo
  planType       PackageType? // Tipo de plano atual
  maxUsers       Int? // Limite de usuГѓВЎrios
  maxProperties  Int? // Limite de imГѓВіveis
  maxLeads       Int? // Limite de leads
  features       Json? // Recursos disponГѓВ­veis no plano
  settings       Json? // ConfiguraГѓВ§ГѓВµes personalizadas
  primaryColor   String? // Cor primГѓВЎria da marca (White Label)
  secondaryColor String? // Cor secundГѓВЎria da marca (White Label)
  isPlatform     Boolean      @default(false) // Indica se Г© a organizaГ§ГЈo gestora (ImobWeb)
  roleQuotas     Json? // Limites de usuГЎrios por papel (ex: {"AGENCY_SALES": 10})
  subDomain      String?      @unique // SubdomГѓВ­nio exclusivo da imobiliГѓВЎria
  createdAt      DateTime     @default(now()) // Data de criaГѓВ§ГѓВЈo
  updatedAt      DateTime     @updatedAt // Data de atualizaГѓВ§ГѓВЈo

  // Relacionamentos
  users              User[] // UsuГѓВЎrios da organizaГѓВ§ГѓВЈo
  properties         Property[] // ImГѓВіveis da organizaГѓВ§ГѓВЈo
  leads              Lead[] // Leads da organizaГѓВ§ГѓВЈo
  subscriptions      Subscription[] // Assinaturas da organizaГѓВ§ГѓВЈo
  apiKeys            ApiKey[] // Chaves de API da organizaГѓВ§ГѓВЈo
  auditLogs          AuditLog[]
  contracts          Contract[] // Contratos da organizaГѓВ§ГѓВЈo
  portalIntegrations PortalIntegration[] // IntegraГѓВ§ГѓВµes com portais
  communicationUsage CommunicationUsage[]
  communicationQuota CommunicationQuota[]
  integrationEvents  IntegrationEvent[]
  autoBlockConfigs   AutoBlockConfig[]
  onboardingProgresses OnboardingProgress[]
  adoptionMetrics      AdoptionMetrics[]
  resellerClient       ResellerClient?

  // ComentГѓВЎrios
  /// OrganizaГѓВ§ГѓВЈo principal para suporte multi-tenant
  /// Cada organizaГѓВ§ГѓВЈo representa uma imobiliГѓВЎria diferente

  // ГѓпїЅndices
  @@index([cnpj])
  @@index([email])
  @@index([city])
}

/// Modelo de ImГѓВіveis (com +80 campos detalhados)
model Property {
