  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // ComentГғВЎrios
  /// Chaves de API para acesso programГғВЎtico de terceiros
  /// Armazena apenas o hash da chave por seguranГғВ§a

  // ГғпҝҪndices
  @@index([organizationId])
  @@index([keyHash])
}

/// Modelo de IntegraГғВ§ГғВөes com Portais
model PortalIntegration {
