  metadata       Json? // Metadados adicionais
  processedAt    DateTime? // Data de processamento
  createdAt      DateTime      @default(now()) // Data de criaГѓВ§ГѓВЈo
  updatedAt      DateTime      @updatedAt // Data de atualizaГѓВ§ГѓВЈo

  // Relacionamentos
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // ComentГѓВЎrios
  /// HistГѓВіrico completo de pagamentos
  /// Suporte a mГѓВєltiplos mГѓВ©todos de pagamento
  /// Rastreabilidade de transaГѓВ§ГѓВµes

  // ГѓпїЅndices
  @@index([subscriptionId])
  @@index([status])
  @@index([paymentMethod])
  @@index([transactionId])
  @@index([createdAt])
}

/// Modelo de NotificaГѓВ§ГѓВµes
model Notification {
  id        String           @id @default(cuid())
  title     String // TГѓВ­tulo da notificaГѓВ§ГѓВЈo
  message   String // Mensagem da notificaГѓВ§ГѓВЈo
  type      NotificationType // Tipo de notificaГѓВ§ГѓВЈo
  status    String           @default("unread") // Status da notificaГѓВ§ГѓВЈo
  userId    String // ID do usuГѓВЎrio
  metadata  Json? // Metadados adicionais
  readAt    DateTime? // Data de leitura
  createdAt DateTime         @default(now()) // Data de criaГѓВ§ГѓВЈo
  updatedAt DateTime         @updatedAt // Data de atualizaГѓВ§ГѓВЈo

  // Relacionamentos
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ComentГѓВЎrios
  /// Sistema de notificaГѓВ§ГѓВµes do plataforma
  /// Diferentes tipos de notificaГѓВ§ГѓВµes
  /// Sistema de leitura e status

  // ГѓпїЅndices
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([readAt])
}

/// Modelo de CaracterГѓВ­sticas Personalizadas de ImГѓВіveis
model PropertyFeature {
  id         String   @id @default(cuid())
  propertyId String // ID do imГѓВіvel
  name       String // Nome da caracterГѓВ­stica
  value      String // Valor da caracterГѓВ­stica
  category   String? // Categoria da caracterГѓВ­stica
  order      Int      @default(0) // Ordem de exibiГѓВ§ГѓВЈo
  isActive   Boolean  @default(true) // EstГѓВЎ ativa
  createdAt  DateTime @default(now()) // Data de criaГѓВ§ГѓВЈo
  updatedAt  DateTime @updatedAt // Data de atualizaГѓВ§ГѓВЈo

  // Relacionamentos
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // ComentГѓВЎrios
  /// CaracterГѓВ­sticas personalizadas de imГѓВіveis
  /// Sistema de categorizaГѓВ§ГѓВЈo e ordenaГѓВ§ГѓВЈo
  /// Extensibilidade do sistema de caracterГѓВ­sticas

  // ГѓпїЅndices
  @@index([propertyId])
  @@index([category])
  @@index([name])
  @@index([order])
}

// ============================================
// IA 4 - AUDIT LOG (SEGURANГѓвЂЎA ENTERPRISE)
// ============================================

/// Tipo de aГѓВ§ГѓВЈo auditada
enum AuditAction {
  CREATE // CriaГѓВ§ГѓВЈo de registro
  UPDATE // AtualizaГѓВ§ГѓВЈo de registro
  DELETE // ExclusГѓВЈo de registro
  READ // Leitura de registro
  LOGIN // Login de usuГѓВЎrio
  LOGOUT // Logout de usuГѓВЎrio
  SEARCH // Pesquisa de dados
  ACCESS // Acesso a recurso sensГѓВ­vel
  EXPORT // ExportaГѓВ§ГѓВЈo de dados
  IMPORT // ImportaГѓВ§ГѓВЈo de dados
  PUBLISH // PublicaГѓВ§ГѓВЈo (ex: portais)
  REVOKE // RevogaГѓВ§ГѓВЈo de acesso
  APPROVE // AprovaГѓВ§ГѓВЈo
  REJECT // RejeiГѓВ§ГѓВЈo
  SEND // Envio de mensagem
  RECEIVE // Recebimento de mensagem
  PASSWORD_CHANGE // AlteraГѓВ§ГѓВЈo de senha
  SETTINGS_CHANGE // AlteraГѓВ§ГѓВЈo de configuraГѓВ§ГѓВµes
}

/// Entidade auditada
enum AuditEntity {
  USER // UsuГѓВЎrio
  ORGANIZATION // OrganizaГѓВ§ГѓВЈo
  PROPERTY // ImГѓВіvel
  LEAD // Lead
  OWNER // ProprietГѓВЎrio
  CONVERSATION // Conversa
  ANNOUNCEMENT // AnГѓВєncio
  PACKAGE // Pacote
  SUBSCRIPTION // Assinatura
  PAYMENT // Pagamento
  NOTIFICATION // NotificaГѓВ§ГѓВЈo
}

/// NГѓВ­vel de risco da aГѓВ§ГѓВЈo
enum AuditRiskLevel {
  LOW // Baixo risco
  MEDIUM // MГѓВ©dio risco
  HIGH // Alto risco
  CRITICAL // Risco crГѓВ­tico
}

/// Modelo de Auditoria (AuditLog)
model AuditLog {
  id String @id @default(cuid())

  // IdentificaГѓВ§ГѓВЈo da aГѓВ§ГѓВЈo
  action     AuditAction // Tipo de aГѓВ§ГѓВЈo realizada
  entityType String? // Tipo da entidade afetada (Property, Lead, User)
  entityId   String? // ID do registro afetado

  // Dados da aГѓВ§ГѓВЈo
  beforeValues Json? // Estado anterior
  afterValues  Json? // Estado posterior
  diff         Json? // DiferenГѓВ§a entre estados
  metadata     Json? // Metadados adicionais
  description  String? // DescriГѓВ§ГѓВЈo da aГѓВ§ГѓВЈo

  // Contexto de seguranГѓВ§a
  ipAddress String? // EndereГѓВ§o IP do usuГѓВЎrio
  userAgent String? // User Agent do navegador
  sessionId String? // ID da sessГѓВЈo

  // ClassificaГѓВ§ГѓВЈo de risco
  riskLevel   AuditRiskLevel @default(LOW)
  containsPII Boolean        @default(false) // ContГѓВ©m dados pessoais
  isSensitive Boolean        @default(false) // ContГѓВ©m dados sensГѓВ­veis

  // Relacionamentos
  userId         String? // UsuГѓВЎrio que realizou a aГѓВ§ГѓВЈo
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String? // OrganizaГѓВ§ГѓВЈo relacionada
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Timestamps
  timestamp DateTime @default(now()) // Quando ocorreu
  createdAt DateTime @default(now())

  // ГѓпїЅndiices para performance
  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([timestamp])
  @@index([riskLevel])
  @@index([entityType, entityId])
}

