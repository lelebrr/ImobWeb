# Variáveis de Ambiente para Vercel
# Copie este arquivo para .env.local para desenvolvimento local
# Configure estas variáveis no Vercel Dashboard > Settings > Environment Variables

# App Configuration
NEXT_PUBLIC_APP_URL=https://imobweb.com
NEXT_PUBLIC_SITE_URL=https://imobweb.com
NEXT_PUBLIC_API_URL=https://api.imobweb.com

# Database
DATABASE_URL=postgresql://username:password@host:port/database

# Authentication
NEXTAUTH_URL=https://imobweb.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# Redis
REDIS_URL=redis://username:password@host:port

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Email Provider
RESEND_API_KEY=your-resend-api-key

# WhatsApp Business
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=whatsapp:+5511999999999

# Analytics
POSTHOG_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# File Upload
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMS Provider
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+5511999999999

# Maps Provider
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# CRM Integration
HUBSPOT_API_KEY=your-hubspot-api-key
ZAPIER_WEBHOOK_URL=your-zapier-webhook-url

# Monitoring
LOGTAIL_TOKEN=your-logtail-token

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key

# Marketplace
MARKETPLACE_API_KEY=your-marketplace-api-key

# Franchise
FRANCHISE_API_KEY=your-franchise-api-key