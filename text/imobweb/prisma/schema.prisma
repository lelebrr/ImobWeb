/// Log de Auditoria para Operações de Backup (LGPD)
model BackupLog {
  id           String   @id @default(cuid())
  backupId     String // ID externo ou da tarefa
  status       String // SUCCESS, FAILED, PENDING
  duration     Int? // Duração em ms
  size         Int? // Tamanho em bytes
  errorMessage String? // Mensagem de erro se houver
  type         String // FULL, INCREMENTAL, RESTORE
  executedAt   DateTime @default(now())

  @@index([backupId])
  @@index([status])
}

/// Modelo de Contratos
model Contract {
  id              String           @id @default(cuid())
  templateId      String?
  type            String // sale, rent, proposal, authorization, commercial
  status          String // draft, pending_review, etc.
  title           String
  description     String?          @db.Text
  totalValue      Decimal?         @db.Decimal(15, 2)
  installments    Int?
  startDate       DateTime?
  endDate         DateTime?
  expiresAt       DateTime?
  signedAt        DateTime?
  documentUrl     String?
  documentVersion Int              @default(1)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?

  // Relacionamentos
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyId      String?
  property        Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  parties         ContractParty[]
  clauses         ContractClause[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([type])
  @@index([status])
}

/// Partes envolvidas no contrato
model ContractParty {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type         String // buyer, seller, tenant, landlord, witness, guarantor
  name         String
  document     String
  documentType String // cpf, cnpj, rg
  email        String
  phone        String
  address      String?
  status       String   @default("pending") // pending, sent, viewed, signed, etc.

  @@index([contractId])
}

/// Cláusulas do contrato
model ContractClause {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  order      Int
  required   Boolean  @default(true)
  custom     Boolean  @default(false)

  @@index([contractId])
}

/// Tipo de ação para auditoria
enum AuditAction {
  CREATE // Criação de registro
  UPDATE // Atualização de registro
  DELETE // Exclusão de registro
  LOGIN // Login de usuário
  LOGOUT // Logout de usuário
  SEARCH // Pesquisa de dados
  ACCESS // Acesso a recurso sensível
  EXPORT // Exportação de dados
  PUBLISH // Publicação (ex: portais)
  REVOKE // Revogação de acesso
  PASSWORD_CHANGE // Alteração de senha
  SETTINGS_CHANGE // Alteração de configurações
}

/// Modelo de Logs de Auditoria (Para conformidade SOC2/LGPD)
model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction // Ação realizada
  entityType     String? // Tipo da entidade afetada (Property, Lead, User)
  entityId       String? // ID da entidade afetada
  userId         String? // ID do usuário que realizou a ação
  user           User?       @relation(fields: [userId], references: [id])
  organizationId String? // ID da organização para multi-tenant
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ipAddress      String? // IP da origem da ação
  userAgent      String? // Navegador/Sistema da origem
  beforeValues   String? // Estado anterior (JSON string)
  afterValues    String? // Estado posterior (JSON string)
  diff           String? // Diferença entre estados (JSON string)
  metadata       String? // Metadados adicionais (JSON string)
  createdAt      DateTime    @default(now()) // Carimbo de tempo da ação

  // Índices para performance de auditoria
  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}
